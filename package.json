{
  "name": "aipush",
  "version": "1.0.0",
  "main": "index.js",
  "overrides": {
    "fast-xml-parser": "$fast-xml-parser"
  },
  "bin": {
    "aipush": "./src/cli/index.ts"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "dev:debug": "tsx watch --inspect src/server.ts",
    "dev:web": "vite --root webapp",
    "start": "node dist/server.js",
    "build": "tsc",
    "build:web": "vite build --root webapp",
    "build:clean": "npm run clean && npm run build",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "typecheck:web": "tsc --project tsconfig.web.json --noEmit",
    "preview:web": "vite preview --root webapp",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "lint": "eslint 'src/**/*.ts' 'tests/**/*.ts'",
    "lint:fix": "eslint 'src/**/*.ts' 'tests/**/*.ts' --fix",
    "format": "prettier --write 'src/**/*.{ts,js,json}'",
    "format:check": "prettier --check 'src/**/*.{ts,js,json}'",
    "migrate:create": "node-pg-migrate create --migration-file-language js",
    "migrate:up": "runuser -u aipush -- bash -lc 'cd /opt/aipush && set -a; . /opt/aipush/.env; set +a; ./node_modules/.bin/node-pg-migrate up --database-url-var DATABASE_URL --migrations-table pgmigrations --schema public --migrations-dir \"migrations/*.js\" --use-glob'",
    "migrate:down": "runuser -u aipush -- bash -lc 'cd /opt/aipush && set -a; . /opt/aipush/.env; set +a; ./node_modules/.bin/node-pg-migrate down --database-url-var DATABASE_URL --migrations-table pgmigrations --schema public --migrations-dir \"migrations/*.js\" --use-glob'",
    "migrate:redo": "node-pg-migrate redo",
    "migrate:status": "node -e \"console.log('Use: npm run migrate:dbstatus')\"",
    "migrate:dbstatus": "psql \"$DATABASE_URL\" -c \"SELECT * FROM pgmigrations ORDER BY run_on DESC;\"",
    "migrate:repair": "runuser -u aipush -- bash -lc 'cd /opt/aipush && bash ./migrate-repair.sh'",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f",
    "docker:ps": "docker-compose ps",
    "docker:clean": "docker-compose down -v",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "prestart": "npm run build",
    "prepare": "npm run build || echo 'Build failed'",
    "spec:compile": "tsx tools/spec-compile.ts",
    "spec:watch": "tsx watch tools/spec-compile.ts",
    "mip:smoke:enqueue": "node dist/mip/scripts/loadSmokeEnqueue.js",
    "mip:smoke:monitor": "node dist/mip/scripts/loadSmokeMonitor.js",
    "mip:check-guard": "bash src/mip/worker/check-mip-guard.sh",
    "admin:dedup:auto-clean": "tsx src/admin/dedup/autoCleanDuplicates.ts",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:landing": "playwright test tests/e2e/specs/landing.spec.ts",
    "test:e2e:login": "playwright test tests/e2e/specs/login.spec.ts",
    "test:e2e:audit": "playwright test tests/e2e/specs/audit.spec.ts",
    "test:e2e:onboard": "playwright test tests/e2e/specs/onboarding.spec.ts",
    "test:e2e:client": "playwright test tests/e2e/specs/client-dashboard.spec.ts",
    "test:e2e:master": "playwright test tests/e2e/specs/master-e2e.spec.ts",
    "test:e2e:2fa": "playwright test tests/e2e/specs/twofa.spec.ts",
    "test:e2e:auth-guard": "playwright test tests/e2e/specs/auth-guard.spec.ts",
    "test:e2e:login-edge": "playwright test tests/e2e/specs/login-edge.spec.ts",
    "test:e2e:billing": "playwright test tests/e2e/specs/billing.spec.ts",
    "test:e2e:dash-ext": "playwright test tests/e2e/specs/dashboard-extended.spec.ts",
    "test:e2e:content": "playwright test tests/e2e/specs/content-pages.spec.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "devDependencies": {
    "@apidevtools/swagger-parser": "^12.1.0",
    "@playwright/test": "^1.58.2",
    "@storybook/addon-essentials": "^8.6.14",
    "@storybook/addon-interactions": "^8.6.14",
    "@storybook/addon-links": "^8.6.14",
    "@storybook/blocks": "^8.6.14",
    "@storybook/react": "^8.6.14",
    "@storybook/react-vite": "^8.6.14",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/cookie": "^0.6.0",
    "@types/express": "^5.0.6",
    "@types/ioredis": "^4.28.10",
    "@types/node": "^25.1.0",
    "@types/pg": "^8.16.0",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.2.9",
    "@types/react-dom": "^19.2.3",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^8.53.1",
    "@typescript-eslint/parser": "^8.53.1",
    "@vitejs/plugin-react": "^5.1.2",
    "@vitest/coverage-v8": "^4.0.17",
    "@vitest/ui": "^4.0.17",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "happy-dom": "^20.3.7",
    "jsdom": "^27.4.0",
    "node-pg-migrate": "^8.0.4",
    "nodemon": "^3.1.11",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.8.1",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "storybook": "^8.6.14",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vitest": "^4.0.17",
    "yaml": "^2.8.2"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.974.0",
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^11.2.0",
    "@fastify/postgres": "^6.0.2",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/static": "^9.0.0",
    "@noble/curves": "^1.9.7",
    "@noble/hashes": "^1.8.0",
    "@octokit/rest": "^22.0.1",
    "@scure/bip32": "^1.7.0",
    "@sentry/node": "^10.40.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/nodemailer": "^7.0.5",
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "chalk": "^4.1.2",
    "dotenv": "^17.2.3",
    "fast-xml-parser": "^5.5.6",
    "fastify": "^5.7.1",
    "google-ads-api": "^23.0.0",
    "ioredis": "^5.9.2",
    "jsonwebtoken": "^9.0.3",
    "nodemailer": "^7.0.12",
    "pdf-lib": "^1.17.1",
    "pg": "^8.17.2",
    "playwright": "^1.58.2",
    "puppeteer-core": "^24.36.0",
    "qrcode": "^1.5.4",
    "react-router-dom": "^7.12.0",
    "resend": "^6.9.1",
    "stripe": "^20.2.0",
    "tldts": "^6.1.0",
    "ws": "^8.19.0"
  }
}
